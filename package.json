{
  "name": "unified-dev-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo type-check",
    "typecheck": "pnpm -w run type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "test": "turbo test",
    "check": "pnpm lint && pnpm type-check && pnpm test",
    "fix": "pnpm lint:fix && pnpm format",
    "reset": "pnpm clean && pnpm install",
    "validate-env": "node scripts/validate-env.js",
    "ci:validate-env": "node scripts/ci-validate-env.js",
    "validate-devops": "node scripts/validate-devops.js",
    "dev:web": "cd apps/web && pnpm dev",
    "dev:api": "cd apps/api && pnpm dev",
    "dev:mobile": "cd apps/mobile && pnpm start",
    "dev:all": "turbo dev --parallel",
    "prebuild": "pnpm check && pnpm validate-env",
    "postinstall": "pnpm type-check",
    "check:console": "node scripts/replace-console-with-logger.cjs --dry-run --report=artifacts/console-replace-report.json",
    "apply:console": "node scripts/replace-console-with-logger.cjs --apply --report=artifacts/console-replace-report.json",
    "mark:cli": "node scripts/mark-cli-no-console.cjs",
    "test:scripts": "node scripts/__tests__/replace-console.test.cjs"
  },
  "devDependencies": {
    "@udp/eslint-config": "workspace:*",
    "@udp/prettier-config": "workspace:*",
  "eslint": "^9.36.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3",
    "dotenv": "^16.1.4"
  }
}
