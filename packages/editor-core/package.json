{
  "name": "@udp/editor-core",
  "version": "0.0.1",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && pnpm exec esbuild index.ts yjs-singleton.ts ProjectSyncManager.ts awareness.ts OfflinePersistence.ts types.ts --format=esm --platform=node --target=node18 --outdir=dist --outbase=. --bundle=false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "jest --config ../../jest.config.cjs --rootDir ."
  },
  "dependencies": {
    "@udp/filesystem": "workspace:*",
    "@udp/logger": "workspace:*",
    "y-indexeddb": "^9.0.12"
  },
  "peerDependencies": {
    "yjs": "^13.6.27",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0"
  },
  "devDependencies": {
    "@udp/eslint-config": "workspace:*",
    "@udp/prettier-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  },
  "eslintConfig": {
    "extends": [
      "@udp/eslint-config/typescript"
    ]
  },
  "prettier": "@udp/prettier-config"
}
