{
  "extends": "../tsconfig.base.react.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": true,
    "declaration": true,
    "outDir": "./dist",
    "noUnusedParameters": false,
    "paths": {
      "@udp/ui": [
        "../ui/index.ts"
      ],
      "@udp/logger": [
        "../logger/index.ts"
      ]
    }
  },
  "include": [
    "index.ts",
    "AIAssistant.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}