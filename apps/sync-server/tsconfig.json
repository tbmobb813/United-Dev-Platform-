{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "jest", "ws"],
    "jsx": "react-jsx",
    "paths": {
      "@udp/*": ["../../packages/*/index.ts", "../../packages/*/src/index.ts", "../../packages/*"]
