{
  "name": "@udp/api",
  "version": "0.0.2",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "start": "NODE_ENV=production node server.js",
    "build": "echo \"No build step for api\"",
    "test": "jest --config ../../jest.config.cjs",
    "test:unit": "jest --config ../../jest.config.cjs --testPathPattern=__tests__/(?!integration)",
    "test:integration": "TEST_INTEGRATION=1 jest --config ../../jest.config.cjs --testPathPattern=integration",
    "test:watch": "jest --config ../../jest.config.cjs --watch",
    "test:coverage": "jest --config ../../jest.config.cjs --coverage"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^6.17.1",
    "@udp/db": "workspace:*",
    "@udp/editor-core": "workspace:*",
    "@udp/logger": "workspace:*",
    "fastify": "^4.28.1",
    "lib0": "^0.2.114",
    "next-auth": "^4.24.12",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  }
}
